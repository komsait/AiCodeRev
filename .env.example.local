# Local Development Environment Variables

# Django Settings
SECRET_KEY=local_development_secret_key_do_not_use_in_production
DEBUG=True

# Database Settings (Local Postgres via Docker)
# If using the docker-compose.yml provided, the db container will automatically pick these up.
DB_NAME=ai_coderev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# AI Provider API Keys (Required for inference)
# You only need to fill out the ones you intend to use.
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
