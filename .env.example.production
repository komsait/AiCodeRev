# Production Deployment Environment Variables

# Django Settings
# Generate a strong, random secret key for production
SECRET_KEY=0tdnitf96(2xd&u6ctrplr33)f+oork6c=eh65sdv_d@0v%_o%
# Must be set to False in production
DEBUG=False

# Allowed Hosts
# Comma-separated list of allowed domains (e.g., your-app.railway.app, www.example.com)
ALLOWED_HOSTS=your-app.railway.app,localhost,127.0.0.1

# Database Configuration
# Most VPS/PaaS providers (like Railway or Heroku) provide a single DATABASE_URL
# It automatically configures DB_NAME, DB_USER, DB_PASSWORD, DB_HOST, and DB_PORT
DATABASE_URL=postgres://user:password@host:port/dbname

# AI Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
